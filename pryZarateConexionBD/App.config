<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
    <connectionStrings>
        <add name="JuegoRPG"
             connectionString="Provider=Microsoft.ACE.OLEDB.12.0;Data Source=|DataDirectory|\BaseDatos\baseJuegoRPG.accdb;Persist Security Info=False;"
             providerName="System.Data.OleDb" />
    </connectionStrings>
</configuration>
